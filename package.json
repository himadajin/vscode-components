{
  "name": "vscode-components-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.29.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "npm run dev --workspace=@himadajin/vscode-components",
    "dev:extension": "npm run dev --workspace=vscode-components-preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:storybook": "npm run build:storybook --workspace=@himadajin/vscode-components",
    "publish:dry-run": "npm publish --dry-run --workspace=@himadajin/vscode-components --access public",
    "check": "npm run lint && npm run typecheck && npm run format:check"
  }
}
