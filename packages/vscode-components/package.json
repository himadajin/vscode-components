{
  "name": "@himadajin/vscode-components",
  "version": "0.1.0",
  "description": "React component library for building VS Code-like interfaces.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "vscode",
    "react",
    "components",
    "ui",
    "webview"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme/defaults.css": "./dist/theme/defaults.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/himadajin/vscode-components.git"
  },
  "homepage": "https://github.com/himadajin/vscode-components#readme",
  "bugs": {
    "url": "https://github.com/himadajin/vscode-components/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@vscode-elements/elements": "^1.13.0",
    "@vscode/codicons": "^0.0.45"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.3.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "storybook": "10.3.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "build:storybook": "storybook build"
  }
}
